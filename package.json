{
  "name": "agentbudget-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source dashboard and demo app for live AgentBudget spend tracking",
  "scripts": {
    "dev": "bash -lc 'source ./set_env.sh >/dev/null 2>&1 || true; tsx watch src/demo/server.ts'",
    "start": "bash -lc 'source ./set_env.sh >/dev/null 2>&1 || true; tsx src/demo/server.ts'",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@agentbudget/agentbudget": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
